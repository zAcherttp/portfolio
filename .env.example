# Required: GitHub contribution graph API
GITHUB_USERNAME=
GITHUB_CONTRIBUTIONS_API_URL=

# Optional: canonical site URL for local or non-Vercel deployments
# Vercel deployments fall back to VERCEL_PROJECT_PRODUCTION_URL or VERCEL_URL.
NEXT_PUBLIC_SITE_URL=

# Optional: raises the GitHub API rate limit for scripts/update-projects.js
GITHUB_TOKEN=

# Optional: points Playwright at an already-running development server
PLAYWRIGHT_BASE_URL=
