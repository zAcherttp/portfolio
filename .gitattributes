# Set default behavior to treat all files as text and use LF line endings on checkout
* text=auto eol=lf

# Force LF for specific source and configuration files
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
