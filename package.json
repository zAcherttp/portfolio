{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "portless": {
    "name": "portfolio",
    "script": "dev:app"
  },
  "scripts": {
    "dev": "portless",
    "dev:app": "next dev",
    "build": "pnpm registry:build && next build",
    "start": "next start",
    "lint": "biome check",
    "check": "biome check --write",
    "format": "biome format --write",
    "test": "vitest",
    "test:run": "vitest run",
    "test:component": "vitest run",
    "test:browser": "playwright test",
    "test:component:browser": "playwright test --project=chromium",
    "test:component:browser:dev": "cross-env PLAYWRIGHT_BASE_URL=https://portfolio.localhost playwright test --project=chromium",
    "registry:build": "pnpm registry:validate && shadcn build",
    "registry:validate": "shadcn registry validate"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.9",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "fumadocs-core": "16.10.5",
    "fumadocs-typescript": "5.2.6",
    "hast-util-to-jsx-runtime": "2.3.6",
    "leva": "^0.10.1",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "postprocessing": "^6.39.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-pretty-code": "0.14.3",
    "rehype-slug": "6.0.0",
    "remark-gfm": "4.0.1",
    "shadcn": "^4.11.0",
    "shiki": "4.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "unist-util-visit": "5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/hast": "^3.0.5",
    "@types/mdx": "^2.0.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "babel-plugin-react-compiler": "1.0.0",
    "cross-env": "^10.1.0",
    "jsdom": "^29.1.1",
    "portless": "0.15.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
